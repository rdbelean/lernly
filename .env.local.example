# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — project URL + keys from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — billing (Pricing v3: 2 subscriptions + 1 one-time product).
# Leave STRIPE_SECRET_KEY empty to disable billing entirely (the routes 503).
# Use the sk_test_ / whsec_ (test) values first; switch to live when verified.
STRIPE_SECRET_KEY=sk_test_...          # Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...        # Webhooks → your endpoint → Signing secret
# Price IDs (Products → <product> → Pricing → "API ID", price_...).
# Prices must match what the landing page advertises (landing-client.tsx).
STRIPE_PRICE_SEMESTER=price_...        # Semester 29,99€ — Subscription, 6-Monats-Intervall
STRIPE_PRICE_MONTHLY=price_...         # Monatlich 8,99€/mo — Subscription, monatlich
STRIPE_PRICE_EINZELKLAUSUR=price_...   # Einzelklausur 4,99€ — One-Time payment (14 Tage Zugang)

# Cram-mode cron worker auth. Vercel Cron sends this as "Authorization: Bearer <value>"
# to /api/cram/worker. Set the SAME value in the Vercel project env (Settings →
# Environment Variables) and here for local testing. Use a long random string.
CRON_SECRET=replace-with-a-long-random-string

# Resend — transactional email (cram-done + Supabase auth via SMTP).
# Create an API key at resend.com → API Keys. The same key works as the SMTP
# password (user "resend", host smtp.resend.com, port 465) for Supabase SMTP.
RESEND_API_KEY=re_...

# --- Monitoring (optional; Sentry stays dormant until DSN is set) ---
NEXT_PUBLIC_SENTRY_DSN=
# For source-map upload on deploy (optional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Generation concurrency cap (optional; default 3) ---
GENERATION_MAX_CONCURRENCY=3

# --- Notion intake + metrics sync (optional; features disable cleanly if unset) ---
# Internal integration token (notion.so/my-integrations). The integration must
# be connected to the Feedback DB, Weekly Metrics DB and Content Calendar
# (Notion page → ⋯ → Connections), otherwise the API returns 403/404.
NOTION_TOKEN=
# Data-source IDs — only set to override the defaults baked into src/lib/notion.ts.
NOTION_FEEDBACK_DB=
NOTION_WEEKLY_METRICS_DB=
NOTION_CONTENT_CALENDAR_DB=

# PostHog private API (weekly metrics queries). PERSONAL API key (phx_...),
# NOT the public phc_ project key. PostHog → Settings → Personal API Keys.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=184383
POSTHOG_HOST=https://eu.posthog.com

# Published Notion feedback form (footer "Feedback geben" link; hidden if unset).
NEXT_PUBLIC_FEEDBACK_FORM_URL=

# B2B landing page /hochschulen: primary CTA target (e.g. Calendly booking
# link). Falls back to mailto:info@lernly-app.de if unset. NEXT_PUBLIC_* ->
# set in ALL Vercel scopes (Production + Preview + Development) and redeploy.
NEXT_PUBLIC_HOCHSCHULEN_CTA_URL=

# --- Admin ops dashboard (/admin) ---
# Founder email allowed to view /admin. Defaults to beleanrd@gmail.com if unset.
ADMIN_EMAIL=

# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — project URL + keys from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — billing (subscriptions + one-time credit packs).
# Leave STRIPE_SECRET_KEY empty to disable billing entirely (the routes 503).
# Use the sk_test_ / whsec_ (test) values first; switch to live when verified.
STRIPE_SECRET_KEY=sk_test_...          # Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...        # Webhooks → your endpoint → Signing secret
# Subscription price IDs (Products → <product> → Pricing → "API ID", price_...).
# Prices must match what the landing page advertises (landing-client.tsx).
STRIPE_PRICE_PRO_MONTHLY=price_...        # Pro 14,99€/mo
STRIPE_PRICE_PRO_BYOK_MONTHLY=price_...   # Pro+Key 11,99€/mo (−3€)
STRIPE_PRICE_TEAM_MONTHLY=price_...       # Team 24,99€/mo (UI noch "BALD" — optional bis Launch)
STRIPE_PRICE_TEAM_BYOK_MONTHLY=price_...  # Team+Key 21,99€/mo (−3€; nicht beworben, optional)
# One-time credit-pack price IDs:
STRIPE_PRICE_SPRINT_PACK=price_...        # Sprint 4,99€ → 5 Pakete, 7 Tage gültig
STRIPE_PRICE_PAYG_PACK=price_...          # Extra-Paket 2,99€ → 1 Paket
STRIPE_PRICE_PAYG_PACK_PRO=price_...      # Extra-Paket Pro/Team 2,49€ → 1 Paket
STRIPE_PRICE_CRAM=price_...               # Cram-Session (alles reinwerfen) 6,99€ einmalig

# Cram-mode cron worker auth. Vercel Cron sends this as "Authorization: Bearer <value>"
# to /api/cram/worker. Set the SAME value in the Vercel project env (Settings →
# Environment Variables) and here for local testing. Use a long random string.
CRON_SECRET=replace-with-a-long-random-string

# Resend — transactional email (cram-done + Supabase auth via SMTP).
# Create an API key at resend.com → API Keys. The same key works as the SMTP
# password (user "resend", host smtp.resend.com, port 465) for Supabase SMTP.
RESEND_API_KEY=re_...

# --- Monitoring (optional; Sentry stays dormant until DSN is set) ---
NEXT_PUBLIC_SENTRY_DSN=
# For source-map upload on deploy (optional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Generation concurrency cap (optional; default 3) ---
GENERATION_MAX_CONCURRENCY=3

# --- Admin ops dashboard (/admin) ---
# Founder email allowed to view /admin. Defaults to beleanrd@gmail.com if unset.
ADMIN_EMAIL=

# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — project URL + keys from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — billing (subscriptions + one-time credit packs).
# Leave STRIPE_SECRET_KEY empty to disable billing entirely (the routes 503).
# Use the sk_test_ / whsec_ (test) values first; switch to live when verified.
STRIPE_SECRET_KEY=sk_test_...          # Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=whsec_...        # Webhooks → your endpoint → Signing secret
# Subscription price IDs (Products → <product> → Pricing → "API ID", price_...):
STRIPE_PRICE_PRO_MONTHLY=price_...        # Pro 6,99€/mo
STRIPE_PRICE_TEAM_MONTHLY=price_...       # Team 14,99€/mo
STRIPE_PRICE_PRO_BYOK_MONTHLY=price_...   # Pro+BYOK 4,99€/mo
STRIPE_PRICE_TEAM_BYOK_MONTHLY=price_...  # Team+BYOK 9,99€/mo
# One-time credit-pack price IDs:
STRIPE_PRICE_SPRINT_PACK=price_...        # Sprint: 5 Pakete, 7 Tage gültig
STRIPE_PRICE_PAYG_PACK=price_...          # PAYG: 1 Paket
STRIPE_PRICE_PAYG_PACK_PRO=price_...      # PAYG für Pro/Team: 1 Paket (rabattiert)
